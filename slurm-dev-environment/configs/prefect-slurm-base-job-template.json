{
  "job_configuration": {
    "command": "{{ command }}",
    "env": "{{ env }}",
    "labels": "{{ labels }}",
    "name": "{{ name }}",
    "cpu": "{{ cpu }}",
    "memory": "{{ memory }}",
    "partition": "{{ partition }}",
    "shebang": "{{ shebang }}",
    "script": "{{ command }}",
    "source_files": "{{ source_files }}",
    "time_limit": "{{ time_limit }}",
    "working_dir": "{{ working_dir }}"
  },
  "variables": {
    "properties": {
      "name": {
        "anyOf": [
          {
            "type": "string"
          },
          {
            "type": "null"
          }
        ],
        "default": null,
        "description": "Name given to infrastructure created by a worker.",
        "title": "Name"
      },
      "env": {
        "additionalProperties": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ]
        },
        "default": {
          "DATABASE_URL": "postgres://postgres:postgres@app-database:5432/emg",
          "DJANGO_DEBUG": "1",
          "DJANGO_SETTINGS_MODULE": "emgapiv2.settings",
          "EMG_SLURM__DEFAULT_WORKDIR": "/nfs/production/dev-slurm-work-dir",
          "NXF_HOME": "/nfs/production/"
        },
        "description": "Environment variables to set when starting a flow run.",
        "title": "Environment Variables",
        "type": "object"
      },
      "labels": {
        "additionalProperties": {
          "type": "string"
        },
        "description": "Labels applied to infrastructure created by a worker.",
        "title": "Labels",
        "type": "object"
      },
      "command": {
        "anyOf": [
          {
            "type": "string"
          },
          {
            "type": "null"
          }
        ],
        "default": null,
        "description": "The command to use when starting a flow run. In most cases, this should be left blank and the command will be automatically generated by the worker.",
        "title": "Command"
      },
      "cpu": {
        "default": 1,
        "description": "CPU count required for the flow",
        "title": "Cpu",
        "type": "integer"
      },
      "memory": {
        "default": 1,
        "description": "Memory in GB required for the flow",
        "title": "Memory",
        "type": "integer"
      },
      "partition": {
        "anyOf": [
          {
            "type": "string"
          },
          {
            "type": "null"
          }
        ],
        "default": null,
        "description": "Slurm partition to use",
        "title": "Partition"
      },
      "shebang": {
        "default": "#!/bin/bash",
        "description": "Indicates which shell to use when running the Slurm job",
        "pattern": "^#!/.+$",
        "title": "Shebang",
        "type": "string"
      },
      "source_files": {
        "default": [
          "/usr/local/bin/prefect-flow-environment.sh"
        ],
        "description": "Environment files sourced before the Prefect flow starts",
        "items": {
          "format": "path",
          "type": "string"
        },
        "title": "Source Files",
        "type": "array"
      },
      "time_limit": {
        "default": 1,
        "description": "Max wall time in hours for the flow",
        "title": "Time Limit",
        "type": "integer"
      },
      "working_dir": {
        "default": "/app",
        "description": "Directory from which to run the flow",
        "format": "path",
        "title": "Working Directory",
        "type": "string"
      }
    },
    "type": "object"
  }
}
